{
  "functions": {
    "source": "functions",
    "predeploy": [
      "pnpm --prefix \"$RESOURCE_DIR\" install --ignore-workspace",
      "pnpm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "apphosting": {
      "startCommand": "pnpm dev",
      "rootDirectory": "."
    }
  },
  "apphosting": {
    "backendId": "backend",
    "rootDir": ".",
    "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "functions"]
  }
}
