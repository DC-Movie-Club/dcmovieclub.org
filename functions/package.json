{
  "name": "dcmovieclub-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for dcmovieclub",
  "main": "lib/index.js",
  "scripts": {
    "build": "pnpm exec tsc",
    "build:watch": "pnpm exec tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.4.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "private": true
}
